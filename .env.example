# ============================================================
# .env.example — Smart Automated Notification & Alerts System
#
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to version control.
# ============================================================

# ── Product to monitor ───────────────────────────────────────
TARGET_URL=https://www.amazon.com/dp/B0EXAMPLE
PRICE_THRESHOLD=799.99       # alert when price drops AT OR BELOW this
ALERT_ON_STOCK=true          # also alert when item comes back in stock

# ── Twilio — SMS alerts ──────────────────────────────────────
# Get these at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15550001234   # your Twilio number
TWILIO_TO_NUMBER=+15559876543     # your personal number

# ── Discord — Webhook alerts ─────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# ── Telegram — Bot alerts ────────────────────────────────────
# 1. Message @BotFather → /newbot to get TELEGRAM_BOT_TOKEN
# 2. Message @userinfobot or check getUpdates to get TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRstuVWXyz
TELEGRAM_CHAT_ID=987654321

# ── Internal config (optional) ───────────────────────────────
STATE_FILE=.state.json
POLL_INTERVAL_SECONDS=3600   # seconds between checks in --loop mode
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
